---
import Base from '../layouts/Base.astro';
---

<Base
  title="Thank You | AC Apparel"
  description="We received your quote request. A team member will contact you within 24 hours with next steps and a flat-rate quote."
  canonicalPath="/thanks"
>
  <section class="py-24 md:py-32">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-6" data-reveal>Request received</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold font-display text-ink tracking-tight leading-tight mb-6" data-reveal>Got it. We'll be in touch inside 24 hours.</h1>
      <p class="text-lg text-graphite leading-relaxed mb-12" data-reveal>A team member will call or email you with next steps and a flat-rate quote.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 mb-16" data-reveal>
        <a href="mailto:info@acapp.us" class="text-2xl md:text-3xl font-extrabold text-accent hover:text-accent-dark transition-colors duration-300">info@acapp.us</a>
        <span class="hidden sm:block text-ink/20">|</span>
        <a href="sms:+17724802284" class="text-lg text-graphite hover:text-accent transition-colors duration-300">(772) 480-2284 <span class="text-xs text-ink/40">Text preferred</span></a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-20" data-reveal>
        <img src="/images/thanks/process-1.webp" alt="Printing press in motion" class="w-full h-64 object-cover" loading="lazy" />
        <img src="/images/thanks/process-2.webp" alt="Packed and ready to ship" class="w-full h-64 object-cover" loading="lazy" />
      </div>
      <h2 class="text-2xl md:text-3xl font-bold font-display text-ink tracking-tight mb-10" data-reveal>See how we work with your industry</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-reveal>
        <a href="/dealerships" class="block bg-paper p-8 hover:bg-ink/5 transition-colors duration-300 text-left">
          <h3 class="font-bold font-display text-ink mb-2">Auto Dealerships</h3>
          <p class="text-sm text-graphite leading-relaxed">Uniforms, lot flags, and event swag.</p>
        </a>
        <a href="/contractors" class="block bg-paper p-8 hover:bg-ink/5 transition-colors duration-300 text-left">
          <h3 class="font-bold font-display text-ink mb-2">Construction &amp; Trades</h3>
          <p class="text-sm text-graphite leading-relaxed">Hi-vis gear and recruitment swag.</p>
        </a>
        <a href="/franchise" class="block bg-paper p-8 hover:bg-ink/5 transition-colors duration-300 text-left">
          <h3 class="font-bold font-display text-ink mb-2">Franchise Owners</h3>
          <p class="text-sm text-graphite leading-relaxed">Brand-compliant merch, no portal headaches.</p>
        </a>
      </div>
    </div>
  </section>
</Base>
