---
import Base from '../layouts/Base.astro';
---

<Base
  title="Photo Credits | AC Apparel"
  description="Photo credits and attributions for images used on the AC Apparel website."
  canonicalPath="/credits"
>
  <section class="py-24 md:py-32">
    <div class="max-w-3xl mx-auto px-6">
      <h1 class="text-4xl md:text-5xl font-bold font-display text-ink tracking-tight mb-6">Photo Credits</h1>
      <p class="text-graphite leading-relaxed">All photos used on this site are sourced from <a href="https://unsplash.com" class="text-accent hover:text-accent-dark transition-colors duration-300">Unsplash</a> under the Unsplash License. Thank you to the photographers who make their work available for free.</p>
    </div>
  </section>
</Base>
