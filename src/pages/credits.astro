---
import Base from '../layouts/Base.astro';
---

<Base
  title="Photo Credits | AC Apparel"
  description="Photo credits and attributions for images used on the AC Apparel website."
  canonicalPath="/credits"
>
  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-4xl font-bold text-slate-900 mb-6">Photo Credits</h1>
      <p class="text-slate-600 mb-8">All photos used on this site are sourced from <a href="https://unsplash.com" class="text-orange-500 hover:text-orange-600">Unsplash</a> under the Unsplash License. Thank you to the photographers who make their work available for free.</p>
    </div>
  </section>
</Base>
