---
import Base from '../layouts/Base.astro';
import LeadForm from '../components/LeadForm.astro';
---

<Base
  title="About AC Apparel | Custom Apparel, Promo, and Print in Tampa FL"
  description="AC Apparel is a custom apparel, promo, and print shop in Tampa, Florida. We print, stitch, and press under one roof."
  canonicalPath="/about"
>

  <!-- Hero -->
  <section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-4" data-reveal>About</p>
      <h1 class="text-5xl md:text-7xl font-extrabold text-charcoal tracking-tighter leading-[0.95] mb-6 max-w-4xl" data-reveal>
        Based in Tampa.<br />Serving the Southeast.
      </h1>
    </div>
  </section>

  <!-- Two-column about -->
  <section class="pb-24 md:pb-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-center">
        <div data-reveal>
          <p class="text-lg md:text-xl text-slate-body leading-relaxed mb-6">
            AC Apparel is a custom apparel, promo, and print shop in Tampa, Florida. We print, stitch, and press under one roof. No middlemen, no reselling, no outsourced production.
          </p>
          <p class="text-lg md:text-xl text-slate-body leading-relaxed mb-6">
            Every order goes through our shop, on our presses, by our people.
          </p>
          <p class="text-lg md:text-xl text-charcoal font-semibold leading-relaxed">
            We built this business around one promise: if we miss your deadline, it ships free. No excuses, no fine print.
          </p>
        </div>
        <div data-reveal>
          <img src="/images/about/hero.webp" alt="AC Apparel shop floor in Tampa" class="w-full h-80 md:h-[28rem] object-cover rounded-sm" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Stats row -->
  <section class="py-16 md:py-20 bg-offwhite">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 text-center" data-reveal>
        <div>
          <p class="text-5xl md:text-6xl font-extrabold text-charcoal tracking-tight">50,000+</p>
          <p class="text-sm text-slate-body mt-2 uppercase tracking-wider font-medium">Units shipped</p>
        </div>
        <div>
          <p class="text-5xl md:text-6xl font-extrabold text-charcoal tracking-tight">200+</p>
          <p class="text-sm text-slate-body mt-2 uppercase tracking-wider font-medium">Businesses served</p>
        </div>
        <div>
          <p class="text-5xl md:text-6xl font-extrabold text-charcoal tracking-tight">7 days</p>
          <p class="text-sm text-slate-body mt-2 uppercase tracking-wider font-medium">Average turnaround</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-4xl md:text-5xl font-extrabold text-charcoal tracking-tight mb-16 text-center" data-reveal>What we stand for</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-16" data-reveal>
        <div class="text-center">
          <div class="w-14 h-14 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-charcoal mb-3">Craftsmanship</h3>
          <p class="text-slate-body leading-relaxed">We care about how it looks, how it feels, and how long it lasts. Water-based inks, dense stitch counts, and finishes that don't crack after three washes.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-charcoal mb-3">Speed</h3>
          <p class="text-slate-body leading-relaxed">Seven-day average turnaround. Mockups in 24 hours. Quotes in 24 hours. We built our operation around not making you wait.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-charcoal mb-3">Straight Talk</h3>
          <p class="text-slate-body leading-relaxed">Flat-rate quotes, no hidden fees, honest timelines. If we can't do it, we'll tell you. If we can, we'll prove it.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="quote" class="bg-dark py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        <div class="flex flex-col justify-center" data-reveal>
          <h2 class="text-4xl md:text-5xl font-extrabold text-white tracking-tight leading-tight mb-6">Ready to start?</h2>
          <p class="text-lg text-white/50 leading-relaxed mb-10">Tell us what you need. Mockup and flat-rate quote inside 24 hours.</p>
          <div class="space-y-3">
            <p><a href="mailto:info@acapp.us" class="text-xl font-bold text-white hover:text-accent transition-colors duration-300">info@acapp.us</a></p>
            <p><a href="sms:+17724802284" class="text-white/50 hover:text-accent transition-colors duration-300">(772) 480-2284 <span class="text-white/30 text-xs">Text preferred</span></a></p>
          </div>
        </div>
        <div data-reveal>
          <LeadForm source="about-page" />
        </div>
      </div>
    </div>
  </section>

</Base>
