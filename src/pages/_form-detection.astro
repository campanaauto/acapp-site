---
/**
 * Hidden form for Netlify's build-time form detection.
 * This page is not linked from navigation. Netlify's crawler
 * reads the static HTML to register form fields.
 */
---

<html lang="en">
  <head><title>Form Detection</title></head>
  <body>
    <form name="lead" data-netlify="true" netlify-honeypot="bot-field" hidden>
      <input name="bot-field" />
      <input name="form-name" value="lead" />
      <input name="source" />
      <input name="utm_source" />
      <input name="utm_medium" />
      <input name="utm_campaign" />
      <input name="utm_content" />
      <input name="utm_term" />
      <input name="submitted_at" />
      <input name="name" />
      <input name="company" />
      <input name="email" />
      <input name="phone" />
      <input name="deadline" />
      <select name="quantity">
        <option value="Under 50">Under 50</option>
        <option value="50 to 250">50 to 250</option>
        <option value="250 to 1000">250 to 1000</option>
        <option value="1000+">1000+</option>
      </select>
      <input type="checkbox" name="needs" value="Apparel" />
      <input type="checkbox" name="needs" value="Promo" />
      <input type="checkbox" name="needs" value="Print" />
      <input type="checkbox" name="needs" value="Not sure yet" />
      <textarea name="notes"></textarea>
    </form>
  </body>
</html>
