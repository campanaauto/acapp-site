---
import Base from '../layouts/Base.astro';
import LeadForm from '../components/LeadForm.astro';
---

<Base
  title="AC Apparel | Custom Apparel, Promo, and Print in Tampa FL"
  description="In-house apparel and print production in Tampa. Seven-day average turnaround. On your deadline or it ships free."
  canonicalPath=""
  mobileQuoteHref="#invitation"
>

  <!-- ============================================= -->
  <!-- SECTION 1: HERO                               -->
  <!-- Two-column, left = copy + inline email form,  -->
  <!-- right = overhead product flat-lay photograph.  -->
  <!-- Primary conversion goal: email capture above   -->
  <!-- the fold with a single-field form posting to   -->
  <!-- Netlify lead endpoint with source tag.         -->
  <!-- ============================================= -->
  <section class="min-h-[88vh] grid grid-cols-1 lg:grid-cols-2">
    <!-- Left column: copy + email form -->
    <div class="bg-paper flex items-center px-8 sm:px-12 md:px-20 py-20 md:py-24 order-2 lg:order-1">
      <div class="max-w-lg">
        <p class="font-sans text-xs font-medium uppercase tracking-[0.2em] text-stone mb-8">Tampa, Florida</p>
        <h1 class="font-display font-normal text-5xl md:text-7xl text-ink tracking-tight leading-[1.0] mb-8">
          Apparel and print,<br />made to a deadline.
        </h1>
        <p class="font-sans text-lg text-graphite max-w-md leading-relaxed mb-12">
          In-house production in Tampa. Seven-day average turnaround. On your deadline or it ships free.
        </p>

        <!-- Inline email capture: underline form -->
        <form
          name="lead"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/thanks"
          class="flex items-end border-b-2 border-ink max-w-md"
          id="hero-form"
          novalidate
        >
          <div class="hidden" aria-hidden="true"><label>Don't fill: <input name="bot-field" tabindex="-1" autocomplete="off" /></label></div>
          <input type="hidden" name="form-name" value="lead" />
          <input type="hidden" name="source" value="homepage-hero" />
          <input type="hidden" name="name" value="" />
          <input type="hidden" name="company" value="" />
          <input type="hidden" name="phone" value="" />
          <input type="hidden" name="quantity" value="" />
          <input type="hidden" name="deadline" value="" />
          <input type="hidden" name="needs" value="" />
          <input type="hidden" name="notes" value="" />
          <input type="hidden" name="utm_source" id="hero-utm-source" value="" />
          <input type="hidden" name="utm_medium" id="hero-utm-medium" value="" />
          <input type="hidden" name="utm_campaign" id="hero-utm-campaign" value="" />
          <input type="hidden" name="utm_content" id="hero-utm-content" value="" />
          <input type="hidden" name="utm_term" id="hero-utm-term" value="" />
          <input type="hidden" name="submitted_at" id="hero-submitted-at" value="" />

          <input
            type="email"
            name="email"
            required
            placeholder="Your work email"
            class="flex-1 h-14 bg-transparent text-ink text-lg font-sans border-0 focus:outline-none placeholder:text-stone/60"
          />
          <button
            type="submit"
            class="h-14 px-8 bg-ink text-white text-sm font-sans font-medium tracking-wide uppercase hover:bg-accent transition-colors duration-300 cursor-pointer whitespace-nowrap shrink-0"
          >
            Request quote
          </button>
        </form>

        <p class="font-sans text-xs text-stone mt-5">We reply within 24 hours. No drip, no catalog spam.</p>
      </div>
    </div>

    <!-- Right column: editorial product photograph -->
    <div class="overflow-hidden order-1 lg:order-2 h-72 sm:h-96 lg:h-auto">
      <img
        src="/images/v4/hero.webp"
        alt="Overhead view of folded apparel and embroidered garments on a warm neutral surface"
        class="w-full h-full object-cover"
      />
    </div>
  </section>

  <script>
    const heroForm = document.getElementById('hero-form') as HTMLFormElement;
    if (heroForm) {
      const params = new URLSearchParams(window.location.search);
      ['utm_source','utm_medium','utm_campaign','utm_content','utm_term'].forEach((k) => {
        const el = document.getElementById('hero-' + k) as HTMLInputElement;
        if (el && params.get(k)) el.value = params.get(k) || '';
      });
      heroForm.addEventListener('submit', (e) => {
        const email = (heroForm.querySelector('input[name="email"]') as HTMLInputElement)?.value;
        if (!email || !email.includes('@')) { e.preventDefault(); return; }
        const ts = document.getElementById('hero-submitted-at') as HTMLInputElement;
        if (ts) ts.value = new Date().toISOString();
      });
    }
  </script>


  <!-- ============================================= -->
  <!-- SECTION 2: THE MASTHEAD                       -->
  <!-- Two-column, left = editorial position copy,   -->
  <!-- right = square product close-up photograph.    -->
  <!-- Role: establish credibility through specifics. -->
  <!-- ============================================= -->
  <section class="bg-paper py-32 md:py-40">
    <div class="max-w-7xl mx-auto px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-20 items-center">
        <div data-reveal>
          <p class="font-sans text-xs font-medium uppercase tracking-[0.2em] text-stone mb-5">About the shop</p>
          <h2 class="font-display font-normal text-4xl md:text-5xl text-ink leading-tight tracking-tight mb-8">
            A print shop built for brands with a deadline.
          </h2>
          <p class="font-sans text-lg text-graphite leading-relaxed mb-10">
            AC Apparel is a Tampa-based shop producing apparel, embroidery, and print in-house. We work with auto groups, construction firms, franchise operators, and event teams across the Southeast. No middlemen, no outsourced production, no surprise charges on the final invoice.
          </p>
          <div class="w-12 h-px bg-accent"></div>
        </div>
        <div class="img-hover" data-reveal>
          <img
            src="/images/v4/masthead.webp"
            alt="Close-up of embroidered thread detail on a polo collar, warm natural light"
            class="w-full aspect-square object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================= -->
  <!-- SECTION 3: CAPABILITIES                       -->
  <!-- Three-column photographic grid with portrait   -->
  <!-- images and editorial capability descriptions.  -->
  <!-- Role: earn credibility through specifics.      -->
  <!-- ============================================= -->
  <section class="py-32 md:py-40">
    <div class="max-w-7xl mx-auto px-8">
      <div class="mb-16 md:mb-20" data-reveal>
        <h2 class="font-display font-normal text-5xl md:text-6xl text-ink tracking-tight">Three things, done in-house.</h2>
        <p class="font-sans text-lg text-stone mt-5 max-w-xl">We screen print, we embroider, and we print. All under one Tampa roof.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12" data-reveal>
        <!-- Screen printing -->
        <div>
          <div class="img-hover overflow-hidden aspect-[4/5] mb-6">
            <img src="/images/v4/cap-screen.webp" alt="Overhead view of screen printing frame with fresh ink on neutral surface" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <p class="font-sans text-xs font-medium uppercase tracking-[0.2em] text-stone mb-3"><span class="text-accent">01</span>  Screen printing</p>
          <h3 class="font-display font-medium text-2xl text-ink mb-3">Water-based inks, ten-color capacity.</h3>
          <p class="font-sans text-graphite leading-relaxed">Soft-hand prints on premium blanks. The finish holds through a season of industrial wash.</p>
        </div>

        <!-- Embroidery -->
        <div>
          <div class="img-hover overflow-hidden aspect-[4/5] mb-6">
            <img src="/images/v4/cap-embroidery.webp" alt="Tight close-up of embroidery thread on fabric showing stitch detail" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <p class="font-sans text-xs font-medium uppercase tracking-[0.2em] text-stone mb-3"><span class="text-accent">02</span>  Embroidery</p>
          <h3 class="font-display font-medium text-2xl text-ink mb-3">Up to fifteen thousand stitches.</h3>
          <p class="font-sans text-graphite leading-relaxed">Dense stitching on polos, caps, and tackle-twill jerseys. Four hundred thread colors held in-house.</p>
        </div>

        <!-- Print -->
        <div>
          <div class="img-hover overflow-hidden aspect-[4/5] mb-6">
            <img src="/images/v4/cap-print.webp" alt="Overhead stack of printed business cards on warm neutral surface" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <p class="font-sans text-xs font-medium uppercase tracking-[0.2em] text-stone mb-3"><span class="text-accent">03</span>  Print and finishing</p>
          <h3 class="font-display font-medium text-2xl text-ink mb-3">Business print, signage, and packaging.</h3>
          <p class="font-sans text-graphite leading-relaxed">Sixteen-point matte cards, uncoated brochures, vinyl signage, and custom die-cuts. Finished and packed in Tampa.</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================= -->
  <!-- SECTION 4: THE GUARANTEE                      -->
  <!-- Full-bleed dark section. Single promise.       -->
  <!-- Role: earn credibility through specificity.    -->
  <!-- ============================================= -->
  <section class="bg-ink py-40 md:py-48">
    <div class="max-w-4xl mx-auto px-8 text-center" data-reveal>
      <p class="font-sans text-xs font-medium uppercase tracking-[0.3em] text-stone mb-12">The promise</p>
      <h2 class="font-display font-light text-5xl md:text-8xl text-white tracking-tight leading-[0.95]">
        On your deadline, or it ships free.
      </h2>
      <div class="py-14 md:py-16"></div>
      <div class="w-16 h-px bg-accent mx-auto"></div>
      <div class="py-8 md:py-10"></div>
      <p class="font-sans text-base text-white/60 max-w-md mx-auto leading-relaxed">Every project. Every client. The same promise, in writing.</p>
    </div>
  </section>


  <!-- ============================================= -->
  <!-- SECTION 5: WORKED WITH (logo wall)            -->
  <!-- Placeholder structure for real client logos.   -->
  <!-- Role: earn credibility through association.    -->
  <!-- ============================================= -->
  <section class="bg-paper py-32">
    <div class="max-w-7xl mx-auto px-8 text-center">
      <p class="font-sans text-xs font-medium uppercase tracking-[0.2em] text-stone mb-12" data-reveal>Worked with</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-x-16 gap-y-12 max-w-5xl mx-auto" data-reveal>
        <!-- REPLACE WITH CLIENT LOGO: grayscale, max-height h-10, width auto. Upload PNG or SVG here. -->
        <div class="aspect-[3/2] flex items-center justify-center"><span class="text-stone/30 text-xs font-sans">Logo</span></div>
        <!-- REPLACE WITH CLIENT LOGO: grayscale, max-height h-10, width auto. Upload PNG or SVG here. -->
        <div class="aspect-[3/2] flex items-center justify-center"><span class="text-stone/30 text-xs font-sans">Logo</span></div>
        <!-- REPLACE WITH CLIENT LOGO: grayscale, max-height h-10, width auto. Upload PNG or SVG here. -->
        <div class="aspect-[3/2] flex items-center justify-center"><span class="text-stone/30 text-xs font-sans">Logo</span></div>
        <!-- REPLACE WITH CLIENT LOGO: grayscale, max-height h-10, width auto. Upload PNG or SVG here. -->
        <div class="aspect-[3/2] flex items-center justify-center"><span class="text-stone/30 text-xs font-sans">Logo</span></div>
        <!-- REPLACE WITH CLIENT LOGO: grayscale, max-height h-10, width auto. Upload PNG or SVG here. -->
        <div class="aspect-[3/2] flex items-center justify-center"><span class="text-stone/30 text-xs font-sans">Logo</span></div>
        <!-- REPLACE WITH CLIENT LOGO: grayscale, max-height h-10, width auto. Upload PNG or SVG here. -->
        <div class="aspect-[3/2] flex items-center justify-center"><span class="text-stone/30 text-xs font-sans">Logo</span></div>
      </div>
      <p class="font-sans text-xs text-stone mt-12" data-reveal>Selected clients across Florida, Georgia, and the Carolinas.</p>
    </div>
  </section>


  <!-- ============================================= -->
  <!-- SECTION 6: BUILT FOR (three verticals)        -->
  <!-- Three-column cards with portrait product       -->
  <!-- images and short editorial descriptions.       -->
  <!-- Role: route to deeper vertical pages.          -->
  <!-- ============================================= -->
  <section class="py-32 md:py-40">
    <div class="max-w-7xl mx-auto px-8">
      <h2 class="font-display font-normal text-5xl md:text-6xl text-ink tracking-tight mb-16 md:mb-20" data-reveal>Built for three kinds of buyer.</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-reveal>
        <!-- Dealerships -->
        <div>
          <div class="img-hover overflow-hidden aspect-[4/5] mb-6">
            <img src="/images/v4/vert-dealers.webp" alt="Overhead view of embroidered polos folded on a warm surface" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <p class="font-sans text-xs font-medium uppercase tracking-[0.2em] text-stone mb-3">For auto dealerships</p>
          <h3 class="font-display font-medium text-2xl text-ink mb-3">For the grand opening that cannot slip.</h3>
          <p class="font-sans text-graphite leading-relaxed mb-4">Service polos, lot flags, and customer gift kits for franchise dealers. We know the co-op deadline.</p>
          <a href="/dealerships" class="font-sans text-sm text-accent border-b border-accent/30 hover:border-accent transition-colors duration-200">See how we work &rarr;</a>
        </div>

        <!-- Contractors -->
        <div>
          <div class="img-hover overflow-hidden aspect-[4/5] mb-6">
            <img src="/images/v4/vert-contractors.webp" alt="Overhead view of hi-vis branded work apparel on neutral surface" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <p class="font-sans text-xs font-medium uppercase tracking-[0.2em] text-stone mb-3">For contractors</p>
          <h3 class="font-display font-medium text-2xl text-ink mb-3">For the crew starting Monday.</h3>
          <p class="font-sans text-graphite leading-relaxed mb-4">Hi-vis uniforms, recruitment swag, and branded workwear for the trades. Staples held in stock.</p>
          <a href="/contractors" class="font-sans text-sm text-accent border-b border-accent/30 hover:border-accent transition-colors duration-200">See how we work &rarr;</a>
        </div>

        <!-- Franchise -->
        <div>
          <div class="img-hover overflow-hidden aspect-[4/5] mb-6">
            <img src="/images/v4/vert-franchise.webp" alt="Overhead view of a folded branded apron on neutral surface" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <p class="font-sans text-xs font-medium uppercase tracking-[0.2em] text-stone mb-3">For franchise operators</p>
          <h3 class="font-display font-medium text-2xl text-ink mb-3">For the opening corporate cannot help with.</h3>
          <p class="font-sans text-graphite leading-relaxed mb-4">Brand-compliant apparel and print, ordered direct from Tampa. No corporate portal.</p>
          <a href="/franchise" class="font-sans text-sm text-accent border-b border-accent/30 hover:border-accent transition-colors duration-200">See how we work &rarr;</a>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================= -->
  <!-- SECTION 7: FINAL INVITATION                   -->
  <!-- Two-column, left = contact copy,               -->
  <!-- right = full LeadForm on dark background.      -->
  <!-- Primary conversion goal: qualified email +     -->
  <!-- project details via the full Netlify form.     -->
  <!-- ============================================= -->
  <section id="invitation" class="bg-ink py-32 md:py-40">
    <div class="max-w-7xl mx-auto px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        <!-- Left -->
        <div data-reveal>
          <p class="font-sans text-xs font-medium uppercase tracking-[0.2em] text-white/50 mb-8">Start a project</p>
          <h2 class="font-display font-normal text-5xl md:text-7xl text-white tracking-tight leading-[0.95] mb-10">Tell us what you need.</h2>
          <p class="font-sans text-lg text-white/60 max-w-md leading-relaxed mb-14">
            Send the details. A quote and a mockup land in your inbox within 24 hours, every time.
          </p>
          <div class="space-y-5">
            <div>
              <p class="font-sans text-xs font-medium uppercase tracking-[0.2em] text-stone mb-2">Email</p>
              <a href="mailto:info@acapp.us" class="font-sans text-lg text-white hover:text-accent transition-colors duration-200">info@acapp.us</a>
            </div>
            <div>
              <p class="font-sans text-xs font-medium uppercase tracking-[0.2em] text-stone mb-2">Text</p>
              <a href="sms:+17724802284" class="font-sans text-lg text-white hover:text-accent transition-colors duration-200">(772) 480-2284</a>
            </div>
          </div>
        </div>

        <!-- Right: form -->
        <div data-reveal>
          <LeadForm source="homepage" />
        </div>
      </div>
    </div>
  </section>

</Base>
