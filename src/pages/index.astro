---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import GuaranteeBlock from '../components/GuaranteeBlock.astro';
import HowItWorks from '../components/HowItWorks.astro';
import VerticalTeaser from '../components/VerticalTeaser.astro';
import LeadForm from '../components/LeadForm.astro';
---

<Base
  title="AC Apparel | Custom Apparel, Promo, and Print in Tampa FL"
  description="Branded apparel, promotional products, and print for businesses. Mockup in 24 hours, flat-rate quotes. On your deadline or it ships free. Tampa, FL."
  canonicalPath=""
>
  <Hero
    title="Branded apparel, promo, and print. On your deadline or it ships free."
    subtitle="Tampa-based, serving businesses across the Southeast. Mockup in 24 hours. Flat-rate quotes."
    ctaText="Get a Quote"
    imageUrl="/images/homepage/hero.webp"
  />

  <TrustBar />
  <ServicesGrid />
  <GuaranteeBlock />
  <HowItWorks />
  <VerticalTeaser />
  <LeadForm source="homepage" />
</Base>
