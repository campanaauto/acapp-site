---
import Base from '../layouts/Base.astro';
import GuaranteeBlock from '../components/GuaranteeBlock.astro';
import LeadForm from '../components/LeadForm.astro';
import StickyQuoteSidebar from '../components/StickyQuoteSidebar.astro';

const products = [
  { name: "Hi-vis branded polos", image: "/images/contractors/product-1.webp" },
  { name: "Safety-compliant outerwear", image: "/images/contractors/product-2.webp" },
  { name: "Job-site hats and beanies", image: "/images/contractors/product-3.webp" },
  { name: "Recruitment tees and bags", image: "/images/contractors/product-4.webp" },
  { name: "Trade show banners", image: "/images/contractors/product-5.webp" },
  { name: "Branded work pants", image: "/images/contractors/product-6.webp" },
];
---

<Base
  title="Custom Apparel for Contractors and Trades | AC Apparel Tampa FL"
  description="Uniforms and recruitment swag for contractors. Hi-vis polos, branded outerwear, job-site hats, and booth gear. On your deadline or it ships free."
  canonicalPath="/contractors"
  ogImage="/images/contractors/hero.webp"
  mobileQuoteHref="#quote"
>

  <StickyQuoteSidebar source="contractors" />

  <section class="relative min-h-[80vh] flex items-end overflow-hidden -mt-[calc(36px+56px)] lg:-mt-[calc(36px+64px)]">
    <div class="absolute inset-0">
      <img src="/images/contractors/hero.webp" alt="Contractor on outdoor job site wearing branded hi-vis polo" class="w-full h-full object-cover scale-105" />
      <div class="absolute inset-0 bg-gradient-to-tr from-black/80 via-black/50 to-transparent"></div>
    </div>
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 pb-20 md:pb-28 pt-40">
      <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-5">Contractors</p>
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-extrabold text-white tracking-tighter leading-[0.95] mb-6 max-w-4xl">Uniforms and swag<br /> for the trades.</h1>
      <p class="text-xl md:text-2xl text-white/90 font-medium mb-3">Ready when your new hires start Monday.</p>
      <p class="text-sm md:text-base text-white/50 mb-10 max-w-xl leading-relaxed">Hi-vis polos, branded outerwear, job-site hats, and recruitment booth gear. Built for the trades, shipped on your schedule.</p>
      <a href="#quote" class="inline-flex items-center justify-center px-8 py-4 bg-accent text-white font-bold text-base rounded-sm hover:bg-accent-dark transition-all duration-300">Get a Contractor Quote</a>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-offwhite">
    <div class="max-w-4xl mx-auto px-6 text-center" data-reveal>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-charcoal tracking-tight leading-tight mb-12">You're tired of…</h2>
      <div class="space-y-6 max-w-2xl mx-auto">
        <p class="text-xl md:text-2xl text-slate-body leading-relaxed">New hires starting without uniforms</p>
        <div class="w-8 h-px bg-accent mx-auto"></div>
        <p class="text-xl md:text-2xl text-slate-body leading-relaxed">Trade show dates creeping up fast</p>
        <div class="w-8 h-px bg-accent mx-auto"></div>
        <p class="text-xl md:text-2xl text-slate-body leading-relaxed">Recruitment booth swag that looks thrown together</p>
      </div>
    </div>
  </section>

  <GuaranteeBlock />

  <section class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-4xl md:text-5xl font-extrabold text-charcoal tracking-tight mb-12 md:mb-16" data-reveal>What we make for contractors.</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" data-reveal>
        {products.map((product) => (
          <div class="group">
            <div class="overflow-hidden rounded-sm mb-4"><img src={product.image} alt={product.name} class="w-full h-64 object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" /></div>
            <p class="text-base font-semibold text-charcoal">{product.name}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-offwhite">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-4xl md:text-5xl font-extrabold text-charcoal tracking-tight mb-12 md:mb-16" data-reveal>How contractors use us.</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-reveal>
        <div class="border-l-2 border-accent pl-6">
          <h3 class="text-xl font-bold text-charcoal mb-3">New crew onboarding</h3>
          <p class="text-slate-body leading-relaxed">50 hi-vis polos with company logo, sized and shipped to the office before the Monday start date.</p>
        </div>
        <div class="border-l-2 border-accent pl-6">
          <h3 class="text-xl font-bold text-charcoal mb-3">Trade show booth gear</h3>
          <p class="text-slate-body leading-relaxed">Banners, staff uniforms, and giveaway tees — coordinated look, one vendor, one shipment.</p>
        </div>
        <div class="border-l-2 border-accent pl-6">
          <h3 class="text-xl font-bold text-charcoal mb-3">Recruitment events</h3>
          <p class="text-slate-body leading-relaxed">Job fair swag bags, branded hard hats, and "We're Hiring" tees that actually look professional.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-6 relative" data-reveal>
        <div class="hidden md:block absolute top-14 left-[12.5%] right-[12.5%] h-px bg-charcoal/10"></div>
        {[
          { n: '01', h: 'Tell us what you need', p: 'Quantity, deadline, and the general idea.' },
          { n: '02', h: 'Mockup in 24 hours', p: 'Approve it, tweak it, or scrap it.' },
          { n: '03', h: 'We print in Tampa', p: 'In-house production. Real shop.' },
          { n: '04', h: 'Ships on your date', p: 'On time or it ships free.' },
        ].map((s) => (
          <div class="relative">
            <p class="text-5xl font-extrabold text-accent mb-5">{s.n}</p>
            <h3 class="text-xl font-bold text-charcoal tracking-tight mb-3">{s.h}</h3>
            <p class="text-slate-body text-sm leading-relaxed">{s.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="quote" class="bg-dark py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        <div class="flex flex-col justify-center" data-reveal>
          <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-4">Contractors</p>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white tracking-tight leading-tight mb-6">Start your<br /> contractor order.</h2>
          <p class="text-lg text-white/50 leading-relaxed mb-10">Get a flat-rate quote inside 24 hours.</p>
          <div class="space-y-3">
            <p><a href="mailto:info@acapp.us" class="text-xl font-bold text-white hover:text-accent transition-colors duration-300">info@acapp.us</a></p>
            <p><a href="sms:+17724802284" class="text-white/50 hover:text-accent transition-colors duration-300">(772) 480-2284 <span class="text-white/30 text-xs">Text preferred</span></a></p>
          </div>
        </div>
        <div data-reveal><LeadForm source="contractors" /></div>
      </div>
    </div>
  </section>

</Base>
