<header class="fixed top-9 left-0 right-0 z-50 bg-white/95 backdrop-blur-md border-b border-soft-border transition-shadow duration-300" id="main-header">
  <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-14 lg:h-16">
    <a href="/" class="font-display text-xl font-bold text-ink tracking-tight">AC APPAREL</a>

    <nav class="hidden lg:flex items-center gap-8">
      <a href="/work" class="text-sm font-medium text-graphite hover:text-ink transition-colors duration-200">Our work</a>
      <a href="/process" class="text-sm font-medium text-graphite hover:text-ink transition-colors duration-200">How we work</a>
      <a href="/about" class="text-sm font-medium text-graphite hover:text-ink transition-colors duration-200">About</a>

      <span class="text-soft-border">|</span>

      <a href="sms:+17724802284" class="text-sm text-stone hover:text-ink transition-colors duration-200">
        <span class="text-stone">Text</span> <span class="font-medium text-ink">(772) 480-2284</span>
      </a>

      <a href="/contact" class="inline-flex items-center px-6 h-10 bg-ink text-white text-sm font-medium tracking-wide uppercase hover:bg-accent transition-colors duration-300">
        Request a quote
      </a>
    </nav>

    <button id="mobile-menu-btn" class="lg:hidden p-2 text-ink" aria-label="Open menu" aria-expanded="false">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden fixed inset-0 top-[calc(36px+56px)] bg-paper z-40 overflow-y-auto pb-32">
    <nav class="flex flex-col items-start px-8 py-12 gap-6">
      <a href="/work" class="font-display text-4xl font-400 text-ink hover:text-accent transition-colors">Our work</a>
      <a href="/process" class="font-display text-4xl font-400 text-ink hover:text-accent transition-colors">How we work</a>
      <a href="/about" class="font-display text-4xl font-400 text-ink hover:text-accent transition-colors">About</a>
      <a href="/dealerships" class="font-display text-4xl font-400 text-ink hover:text-accent transition-colors">Dealerships</a>
      <a href="/contractors" class="font-display text-4xl font-400 text-ink hover:text-accent transition-colors">Contractors</a>
      <a href="/franchise" class="font-display text-4xl font-400 text-ink hover:text-accent transition-colors">Franchise</a>

      <div class="border-t border-soft-border w-full my-4"></div>

      <a href="mailto:info@acapp.us" class="text-base font-medium text-ink">info@acapp.us</a>
      <a href="sms:+17724802284" class="text-base text-stone">(772) 480-2284</a>

      <a href="/contact" class="mt-4 inline-flex items-center justify-center px-8 py-4 bg-ink text-white text-sm font-medium tracking-wide uppercase">
        Request a quote
      </a>
    </nav>
  </div>
</header>

<div class="h-[calc(36px+56px)] lg:h-[calc(36px+64px)]"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const header = document.getElementById('main-header');

  if (btn && menu) {
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
      document.body.style.overflow = isOpen ? '' : 'hidden';
    });
  }

  if (header) {
    window.addEventListener('scroll', () => {
      header.classList.toggle('shadow-sm', window.scrollY > 10);
    });
  }
</script>
