---
interface Props { quoteHref?: string; }
const { quoteHref = '/contact' } = Astro.props;
---
<div class="fixed bottom-0 left-0 right-0 z-50 md:hidden bg-ink safe-bottom">
  <div class="flex h-14">
    <a href="sms:+17724802284" class="flex-1 flex items-center justify-center text-sm font-medium text-white/80 tracking-wide uppercase border-r border-white/10">Text us</a>
    <a href={quoteHref} class="flex-1 flex items-center justify-center text-sm font-medium text-white bg-accent tracking-wide uppercase">Request a quote</a>
  </div>
</div>
<div class="h-14 md:hidden"></div>
