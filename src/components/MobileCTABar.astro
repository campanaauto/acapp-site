---
interface Props {
  quoteHref?: string;
}
const { quoteHref = '/contact' } = Astro.props;
---

<!-- Mobile-only floating CTA bar -->
<div class="fixed bottom-0 left-0 right-0 z-50 md:hidden bg-white border-t border-charcoal/10 safe-bottom">
  <div class="flex h-14">
    <a href="sms:+17724802284" class="flex-1 flex items-center justify-center gap-2 text-sm font-semibold text-charcoal border-r border-charcoal/10">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
      Text Us
    </a>
    <a href={quoteHref} class="flex-1 flex items-center justify-center gap-2 text-sm font-semibold text-white bg-accent">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      Get Quote
    </a>
  </div>
</div>
<!-- Spacer to prevent content overlap on mobile -->
<div class="h-14 md:hidden"></div>
