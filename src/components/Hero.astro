---
interface Props {
  title: string;
  subtitle: string;
  ctaText: string;
  ctaHref?: string;
  imageUrl: string;
}

const { title, subtitle, ctaText, ctaHref = '#quote', imageUrl } = Astro.props;
---

<section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden">
  <img
    src={imageUrl}
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
    decoding="async"
  />
  <div class="absolute inset-0 bg-slate-900/70"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-4 py-20 text-center text-white">
    <h1 class="text-4xl md:text-6xl font-bold mb-6 leading-tight">{title}</h1>
    <p class="text-lg md:text-xl text-slate-200 mb-8 max-w-2xl mx-auto">{subtitle}</p>
    <a
      href={ctaHref}
      class="inline-block bg-orange-500 hover:bg-orange-600 text-white font-bold text-lg px-8 py-4 rounded-lg transition-colors"
    >
      {ctaText}
    </a>
  </div>
</section>
