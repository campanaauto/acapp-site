---
interface Product {
  name: string;
  image: string;
}

interface Props {
  products: Product[];
}

const { products } = Astro.props;
---

<section class="py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-slate-900 text-center mb-12">What We Produce</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
      {products.map((product) => (
        <div class="bg-white rounded-xl shadow-md overflow-hidden">
          <img src={product.image} alt={product.name} class="w-full h-40 md:h-48 object-cover" loading="lazy" />
          <div class="p-4">
            <h3 class="font-bold text-slate-900 text-sm md:text-base">{product.name}</h3>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
