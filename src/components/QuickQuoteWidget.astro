<!-- Floating quick-quote widget, bottom-right, hidden on mobile when CTA bar visible -->
<div id="qq-widget" class="fixed bottom-6 right-6 z-50 hidden md:block">
  <!-- Trigger button -->
  <button
    id="qq-trigger"
    class="bg-accent hover:bg-accent-dark text-white font-semibold text-sm px-5 py-3 rounded-full shadow-lg hover:-translate-y-0.5 transition-all duration-300 flex items-center gap-2 cursor-pointer"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
    Quick Quote
  </button>

  <!-- Expanded panel -->
  <div id="qq-panel" class="qq-panel absolute bottom-16 right-0 w-80 bg-white rounded-sm shadow-2xl border border-charcoal/10 p-6">
    <!-- Close -->
    <button id="qq-close" class="absolute top-3 right-3 text-charcoal/40 hover:text-charcoal transition-colors cursor-pointer">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>

    <h3 class="text-lg font-bold text-charcoal mb-4">Get quick pricing</h3>

    <form
      name="quick-quote"
      method="POST"
      data-netlify="true"
      netlify-honeypot="qq-bot-field"
      action="/thanks"
      id="qq-form"
      class="space-y-3"
      novalidate
    >
      <div class="hidden" aria-hidden="true">
        <label>Don't fill this out: <input name="qq-bot-field" tabindex="-1" autocomplete="off" /></label>
      </div>
      <input type="hidden" name="form-name" value="quick-quote" />
      <input type="hidden" name="source" value="quick-quote-widget" />
      <input type="hidden" name="page_url" id="qq-page-url" value="" />
      <input type="hidden" name="submitted_at" id="qq-submitted-at" value="" />

      <div>
        <label for="qq-email" class="block text-xs font-semibold text-charcoal/60 mb-1">Email *</label>
        <input
          type="email"
          id="qq-email"
          name="email"
          required
          class="w-full h-11 px-3 text-sm rounded-sm bg-offwhite text-charcoal border border-charcoal/10 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all"
          placeholder="you@company.com"
        />
      </div>

      <div>
        <label for="qq-need" class="block text-xs font-semibold text-charcoal/60 mb-1">What do you need?</label>
        <select
          id="qq-need"
          name="need"
          class="w-full h-11 px-3 text-sm rounded-sm bg-offwhite text-charcoal border border-charcoal/10 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all"
        >
          <option value="">Select one</option>
          <option value="Apparel">Apparel</option>
          <option value="Promo">Promo</option>
          <option value="Print">Print</option>
          <option value="Signage">Signage</option>
          <option value="Not sure">Not sure</option>
        </select>
      </div>

      <div>
        <label for="qq-quantity" class="block text-xs font-semibold text-charcoal/60 mb-1">Quantity</label>
        <select
          id="qq-quantity"
          name="quantity"
          class="w-full h-11 px-3 text-sm rounded-sm bg-offwhite text-charcoal border border-charcoal/10 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all"
        >
          <option value="">Select a range</option>
          <option value="Under 50">Under 50</option>
          <option value="50-250">50–250</option>
          <option value="250-1000">250–1,000</option>
          <option value="1000+">1,000+</option>
        </select>
      </div>

      <button type="submit" class="w-full bg-accent hover:bg-accent-dark text-white font-semibold text-sm py-3 rounded-sm transition-all duration-300 cursor-pointer">
        Get Pricing
      </button>
    </form>
  </div>
</div>

<script>
  const trigger = document.getElementById('qq-trigger');
  const panel = document.getElementById('qq-panel');
  const close = document.getElementById('qq-close');
  const pageUrl = document.getElementById('qq-page-url') as HTMLInputElement;

  if (pageUrl) pageUrl.value = window.location.href;

  trigger?.addEventListener('click', () => panel?.classList.toggle('open'));
  close?.addEventListener('click', () => panel?.classList.remove('open'));

  const qqForm = document.getElementById('qq-form') as HTMLFormElement;
  qqForm?.addEventListener('submit', (e) => {
    const email = (qqForm.querySelector('#qq-email') as HTMLInputElement)?.value;
    if (!email || !email.includes('@')) {
      e.preventDefault();
      return;
    }
    const ts = document.getElementById('qq-submitted-at') as HTMLInputElement;
    if (ts) ts.value = new Date().toISOString();
  });
</script>
