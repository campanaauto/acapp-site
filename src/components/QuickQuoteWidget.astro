<div id="qq-widget" class="fixed bottom-6 right-6 z-50 hidden md:block">
  <button id="qq-trigger" class="bg-ink text-white font-sans text-sm font-medium px-5 py-3 shadow-lg hover:-translate-y-0.5 transition-all duration-300 flex items-center gap-2 cursor-pointer tracking-wide">
    Quick pricing
  </button>

  <div id="qq-panel" class="qq-panel absolute bottom-14 right-0 w-80 bg-white shadow-2xl border border-soft-border p-6">
    <button id="qq-close" class="absolute top-3 right-3 text-stone hover:text-ink transition-colors cursor-pointer">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>

    <h3 class="font-display text-lg font-500 text-ink mb-4">Quick pricing</h3>

    <form name="quick-quote" method="POST" data-netlify="true" netlify-honeypot="qq-bot-field" action="/thanks" id="qq-form" class="space-y-3" novalidate>
      <div class="hidden" aria-hidden="true"><label>Don't fill: <input name="qq-bot-field" tabindex="-1" autocomplete="off" /></label></div>
      <input type="hidden" name="form-name" value="quick-quote" />
      <input type="hidden" name="source" value="quick-quote-widget" />
      <input type="hidden" name="page_url" id="qq-page-url" value="" />
      <input type="hidden" name="submitted_at" id="qq-submitted-at" value="" />

      <div>
        <label class="block text-xs font-medium text-stone mb-1 tracking-wide uppercase">Email</label>
        <input type="email" id="qq-email" name="email" required class="w-full h-11 px-4 text-sm bg-paper text-ink border border-soft-border focus:outline-none focus:border-accent transition-colors" placeholder="you@company.com" />
      </div>
      <div>
        <label class="block text-xs font-medium text-stone mb-1 tracking-wide uppercase">What do you need?</label>
        <select id="qq-need" name="need" class="w-full h-11 px-4 text-sm bg-paper text-ink border border-soft-border focus:outline-none focus:border-accent transition-colors">
          <option value="">Select</option>
          <option value="Apparel">Apparel</option>
          <option value="Promo">Promo</option>
          <option value="Print">Print</option>
          <option value="Signage">Signage</option>
          <option value="Not sure">Not sure</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-stone mb-1 tracking-wide uppercase">Quantity</label>
        <select id="qq-quantity" name="quantity" class="w-full h-11 px-4 text-sm bg-paper text-ink border border-soft-border focus:outline-none focus:border-accent transition-colors">
          <option value="">Select</option>
          <option value="Under 50">Under 50</option>
          <option value="50-250">50 to 250</option>
          <option value="250-1000">250 to 1,000</option>
          <option value="1000+">1,000+</option>
        </select>
      </div>
      <button type="submit" class="w-full bg-ink text-white font-medium text-sm py-3 tracking-wide uppercase hover:bg-accent transition-colors duration-300 cursor-pointer">Send</button>
    </form>
  </div>
</div>

<script>
  const trigger = document.getElementById('qq-trigger');
  const panel = document.getElementById('qq-panel');
  const close = document.getElementById('qq-close');
  const pageUrl = document.getElementById('qq-page-url') as HTMLInputElement;
  if (pageUrl) pageUrl.value = window.location.href;
  trigger?.addEventListener('click', () => panel?.classList.toggle('open'));
  close?.addEventListener('click', () => panel?.classList.remove('open'));
  const qqForm = document.getElementById('qq-form') as HTMLFormElement;
  qqForm?.addEventListener('submit', (e) => {
    const email = (qqForm.querySelector('#qq-email') as HTMLInputElement)?.value;
    if (!email || !email.includes('@')) { e.preventDefault(); return; }
    const ts = document.getElementById('qq-submitted-at') as HTMLInputElement;
    if (ts) ts.value = new Date().toISOString();
  });
</script>
