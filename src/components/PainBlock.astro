---
interface Props {
  bullets: string[];
}

const { bullets } = Astro.props;
---

<section class="py-16 md:py-24 bg-slate-50">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-10">You're tired of...</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {bullets.map((bullet) => (
        <div class="bg-white rounded-lg p-6 shadow-sm">
          <div class="text-orange-500 mb-3">
            <svg class="w-8 h-8 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <p class="text-slate-700 font-medium">{bullet}</p>
        </div>
      ))}
    </div>
  </div>
</section>
