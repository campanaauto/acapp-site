<div id="pq-backdrop" class="pq-backdrop fixed inset-0 z-[70] bg-black/50 hidden" aria-hidden="true">
  <div class="flex items-center justify-center min-h-screen p-4">
    <div id="pq-card" class="bg-white shadow-2xl w-full max-w-md p-8 md:p-10 relative">
      <button id="pq-close" class="absolute top-4 right-4 text-stone hover:text-ink transition-colors cursor-pointer" aria-label="Close">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>

      <h3 class="font-display text-2xl font-500 text-ink mb-1" id="pq-title">Request pricing</h3>
      <p class="text-sm text-stone mb-8">We will send a custom quote within 24 hours.</p>

      <form name="product-quote" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thanks" id="pq-form" class="space-y-4" novalidate>
        <div class="hidden" aria-hidden="true"><label>Don't fill: <input name="bot-field" tabindex="-1" autocomplete="off" /></label></div>
        <input type="hidden" name="form-name" value="product-quote" />
        <input type="hidden" name="product_name" id="pq-product-name" value="" />
        <input type="hidden" name="category" id="pq-category" value="" />
        <input type="hidden" name="source" value="product-modal" />
        <input type="hidden" name="submitted_at" id="pq-submitted-at" value="" />
        <input type="hidden" name="utm_source" value="" />
        <input type="hidden" name="utm_medium" value="" />
        <input type="hidden" name="utm_campaign" value="" />
        <input type="hidden" name="utm_content" value="" />
        <input type="hidden" name="utm_term" value="" />

        <div>
          <label class="block text-xs font-medium text-stone mb-1.5 tracking-wide uppercase">Email</label>
          <input type="email" name="email" required class="w-full h-12 px-4 text-sm bg-paper text-ink border border-soft-border focus:outline-none focus:border-accent transition-colors" placeholder="you@company.com" />
        </div>
        <div>
          <label class="block text-xs font-medium text-stone mb-1.5 tracking-wide uppercase">Quantity</label>
          <select name="quantity" required class="w-full h-12 px-4 text-sm bg-paper text-ink border border-soft-border focus:outline-none focus:border-accent transition-colors">
            <option value="">Select a range</option>
            <option value="Under 50">Under 50</option>
            <option value="50 to 250">50 to 250</option>
            <option value="250 to 1000">250 to 1,000</option>
            <option value="1000+">1,000+</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-stone mb-1.5 tracking-wide uppercase">Company</label>
          <input type="text" name="company" required class="w-full h-12 px-4 text-sm bg-paper text-ink border border-soft-border focus:outline-none focus:border-accent transition-colors" placeholder="Company name" />
        </div>
        <div>
          <label class="block text-xs font-medium text-stone mb-1.5 tracking-wide uppercase">Deadline (optional)</label>
          <input type="date" name="deadline" class="w-full h-12 px-4 text-sm bg-paper text-ink border border-soft-border focus:outline-none focus:border-accent transition-colors" />
        </div>
        <div>
          <label class="block text-xs font-medium text-stone mb-1.5 tracking-wide uppercase">Notes (optional)</label>
          <textarea name="notes" rows="2" class="w-full px-4 py-3 text-sm bg-paper text-ink border border-soft-border focus:outline-none focus:border-accent transition-colors" placeholder="Colors, sizes, design notes..."></textarea>
        </div>

        <button type="submit" class="w-full bg-ink text-white font-medium text-sm py-3.5 tracking-wide uppercase hover:bg-accent transition-colors duration-300 cursor-pointer">Request quote</button>
      </form>
    </div>
  </div>
</div>

<script>
  const backdrop = document.getElementById('pq-backdrop');
  const titleEl = document.getElementById('pq-title');
  const productInput = document.getElementById('pq-product-name') as HTMLInputElement;
  const categoryInput = document.getElementById('pq-category') as HTMLInputElement;

  function openModal(productName: string, category: string) {
    if (!backdrop || !titleEl || !productInput || !categoryInput) return;
    titleEl.textContent = productName ? `Request pricing for ${productName}` : 'Request pricing';
    productInput.value = productName;
    categoryInput.value = category;
    backdrop.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    backdrop?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  document.getElementById('pq-close')?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement)?.closest('#pq-card') === null) closeModal();
  });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  document.querySelectorAll('[data-pq-trigger]').forEach((el) => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      openModal((el as HTMLElement).dataset.pqName || '', (el as HTMLElement).dataset.pqCategory || '');
    });
  });

  const pqForm = document.getElementById('pq-form') as HTMLFormElement;
  const params = new URLSearchParams(window.location.search);
  pqForm?.querySelectorAll('input[name^="utm_"]').forEach((el) => {
    const val = params.get((el as HTMLInputElement).name);
    if (val) (el as HTMLInputElement).value = val;
  });
  pqForm?.addEventListener('submit', () => {
    const ts = document.getElementById('pq-submitted-at') as HTMLInputElement;
    if (ts) ts.value = new Date().toISOString();
  });
</script>
