---
interface Props {
  source: string;
  compact?: boolean;
}

const { source, compact = false } = Astro.props;
---

<form
  name="lead"
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  action="/thanks"
  id="lead-form"
  class={compact ? 'space-y-4' : 'space-y-6'}
  novalidate
>
  <!-- Honeypot -->
  <div class="hidden" aria-hidden="true">
    <label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
  </div>

  <!-- Hidden fields -->
  <input type="hidden" name="form-name" value="lead" />
  <input type="hidden" name="source" value={source} />
  <input type="hidden" name="utm_source" id="utm_source" value="" />
  <input type="hidden" name="utm_medium" id="utm_medium" value="" />
  <input type="hidden" name="utm_campaign" id="utm_campaign" value="" />
  <input type="hidden" name="utm_content" id="utm_content" value="" />
  <input type="hidden" name="utm_term" id="utm_term" value="" />
  <input type="hidden" name="submitted_at" id="submitted_at" value="" />

  {compact ? (
    <>
      {/* Compact mode: fewer fields */}
      <div>
        <label for="name" class="block text-xs font-semibold uppercase tracking-wider text-white/60 mb-1.5">Full Name *</label>
        <input type="text" id="name" name="name" required class="w-full h-12 px-4 rounded-sm bg-offwhite text-charcoal border border-charcoal/10 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all duration-300 placeholder:text-charcoal/30 text-sm" placeholder="Your full name" />
        <p class="text-accent text-sm mt-1 hidden" data-error="name">Please enter your name.</p>
      </div>
      <div>
        <label for="email" class="block text-xs font-semibold uppercase tracking-wider text-white/60 mb-1.5">Email *</label>
        <input type="email" id="email" name="email" required class="w-full h-12 px-4 rounded-sm bg-offwhite text-charcoal border border-charcoal/10 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all duration-300 placeholder:text-charcoal/30 text-sm" placeholder="you@company.com" />
        <p class="text-accent text-sm mt-1 hidden" data-error="email">Please enter a valid email.</p>
      </div>
      <div>
        <label for="phone" class="block text-xs font-semibold uppercase tracking-wider text-white/60 mb-1.5">Cell phone for text updates *</label>
        <input type="tel" id="phone" name="phone" required pattern="[\d\s\-\(\)\+]{7,}" class="w-full h-12 px-4 rounded-sm bg-offwhite text-charcoal border border-charcoal/10 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all duration-300 placeholder:text-charcoal/30 text-sm" placeholder="(555) 123-4567" />
        <p class="text-accent text-sm mt-1 hidden" data-error="phone">Please enter a valid phone number.</p>
      </div>
      <div>
        <label for="quantity" class="block text-xs font-semibold uppercase tracking-wider text-white/60 mb-1.5">Estimated Quantity *</label>
        <select id="quantity" name="quantity" required class="w-full h-12 px-4 rounded-sm bg-offwhite text-charcoal border border-charcoal/10 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all duration-300 text-sm">
          <option value="">Select a range</option>
          <option value="Under 50">Under 50</option>
          <option value="50 to 250">50 to 250</option>
          <option value="250 to 1000">250 to 1000</option>
          <option value="1000+">1000+</option>
        </select>
        <p class="text-accent text-sm mt-1 hidden" data-error="quantity">Please select a quantity range.</p>
      </div>
      {/* Hidden fields for compact mode compatibility */}
      <input type="hidden" name="company" value="" />
      <input type="hidden" name="deadline" value="" />
      <input type="hidden" name="needs" value="" />
      <input type="hidden" name="notes" value="" />
      <button type="submit" id="submit-btn" class="w-full bg-accent hover:bg-accent-dark text-white font-bold text-base py-3.5 rounded-sm transition-all duration-300 cursor-pointer">
        Get My Quote
      </button>
      <p class="text-white/40 text-xs">We respond inside 24 hours.</p>
    </>
  ) : (
    <>
      {/* Full mode */}
      <div>
        <label for="name" class="block text-xs font-semibold uppercase tracking-wider text-white/60 mb-2">Full Name *</label>
        <input type="text" id="name" name="name" required class="w-full h-14 px-4 rounded-sm bg-offwhite text-charcoal border border-charcoal/10 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all duration-300 placeholder:text-charcoal/30" placeholder="Your full name" />
        <p class="text-accent text-sm mt-1.5 hidden" data-error="name">Please enter your name.</p>
      </div>
      <div>
        <label for="company" class="block text-xs font-semibold uppercase tracking-wider text-white/60 mb-2">Company *</label>
        <input type="text" id="company" name="company" required class="w-full h-14 px-4 rounded-sm bg-offwhite text-charcoal border border-charcoal/10 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all duration-300 placeholder:text-charcoal/30" placeholder="Company name" />
        <p class="text-accent text-sm mt-1.5 hidden" data-error="company">Please enter your company name.</p>
      </div>
      <div>
        <label for="email" class="block text-xs font-semibold uppercase tracking-wider text-white/60 mb-2">Email *</label>
        <input type="email" id="email" name="email" required class="w-full h-14 px-4 rounded-sm bg-offwhite text-charcoal border border-charcoal/10 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all duration-300 placeholder:text-charcoal/30" placeholder="you@company.com" />
        <p class="text-accent text-sm mt-1.5 hidden" data-error="email">Please enter a valid email address.</p>
      </div>
      <div>
        <label for="phone" class="block text-xs font-semibold uppercase tracking-wider text-white/60 mb-2">Cell phone for text updates *</label>
        <input type="tel" id="phone" name="phone" required pattern="[\d\s\-\(\)\+]{7,}" class="w-full h-14 px-4 rounded-sm bg-offwhite text-charcoal border border-charcoal/10 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all duration-300 placeholder:text-charcoal/30" placeholder="(555) 123-4567" />
        <p class="text-accent text-sm mt-1.5 hidden" data-error="phone">Please enter a valid phone number.</p>
      </div>
      <div>
        <label for="deadline" class="block text-xs font-semibold uppercase tracking-wider text-white/60 mb-2">Deadline or Event Date</label>
        <input type="date" id="deadline" name="deadline" class="w-full h-14 px-4 rounded-sm bg-offwhite text-charcoal border border-charcoal/10 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all duration-300" />
      </div>
      <div>
        <label for="quantity" class="block text-xs font-semibold uppercase tracking-wider text-white/60 mb-2">Estimated Quantity *</label>
        <select id="quantity" name="quantity" required class="w-full h-14 px-4 rounded-sm bg-offwhite text-charcoal border border-charcoal/10 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all duration-300">
          <option value="">Select a range</option>
          <option value="Under 50">Under 50</option>
          <option value="50 to 250">50 to 250</option>
          <option value="250 to 1000">250 to 1000</option>
          <option value="1000+">1000+</option>
        </select>
        <p class="text-accent text-sm mt-1.5 hidden" data-error="quantity">Please select a quantity range.</p>
      </div>
      <fieldset>
        <legend class="block text-xs font-semibold uppercase tracking-wider text-white/60 mb-3">What do you need? *</legend>
        <div class="grid grid-cols-2 gap-3">
          <label class="flex items-center gap-3 text-white/80 text-sm cursor-pointer">
            <input type="checkbox" name="needs" value="Apparel" class="w-4 h-4 rounded-sm text-accent focus:ring-accent accent-accent" />
            Apparel
          </label>
          <label class="flex items-center gap-3 text-white/80 text-sm cursor-pointer">
            <input type="checkbox" name="needs" value="Promo" class="w-4 h-4 rounded-sm text-accent focus:ring-accent accent-accent" />
            Promo
          </label>
          <label class="flex items-center gap-3 text-white/80 text-sm cursor-pointer">
            <input type="checkbox" name="needs" value="Print" class="w-4 h-4 rounded-sm text-accent focus:ring-accent accent-accent" />
            Print
          </label>
          <label class="flex items-center gap-3 text-white/80 text-sm cursor-pointer">
            <input type="checkbox" name="needs" value="Not sure yet" class="w-4 h-4 rounded-sm text-accent focus:ring-accent accent-accent" />
            Not sure yet
          </label>
        </div>
        <p class="text-accent text-sm mt-1.5 hidden" data-error="needs">Please select at least one option.</p>
      </fieldset>
      <div>
        <label for="notes" class="block text-xs font-semibold uppercase tracking-wider text-white/60 mb-2">Notes</label>
        <textarea id="notes" name="notes" rows="4" class="w-full px-4 py-3 rounded-sm bg-offwhite text-charcoal border border-charcoal/10 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all duration-300 placeholder:text-charcoal/30" placeholder="Tell us about your project, colors, quantities, or anything else."></textarea>
      </div>
      <button type="submit" id="submit-btn" class="w-full md:w-auto md:px-12 bg-accent hover:bg-accent-dark text-white font-bold text-lg py-4 rounded-sm transition-all duration-300 cursor-pointer">
        Get My Quote
      </button>
      <p class="text-white/40 text-sm">We respond inside 24 hours.</p>
    </>
  )}

  <!-- Network error message -->
  <p id="form-error" class="text-accent text-center hidden">
    Submission failed. Text us at <a href="sms:+17724802284" class="underline">(772) 480-2284</a> or email <a href="mailto:info@acapp.us" class="underline">info@acapp.us</a>.
  </p>
</form>

<script>
  // Capture UTM params
  const params = new URLSearchParams(window.location.search);
  ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'].forEach((key) => {
    const el = document.getElementById(key) as HTMLInputElement;
    if (el && params.get(key)) {
      el.value = params.get(key) || '';
    }
  });

  const form = document.getElementById('lead-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  if (form && submitBtn) {
    function showError(name: string) {
      const el = form.querySelector(`[data-error="${name}"]`) as HTMLElement;
      if (el) el.classList.remove('hidden');
      const input = form.querySelector(`[name="${name}"]`) as HTMLElement;
      if (input) input.classList.add('!border-accent');
    }

    function clearErrors() {
      form.querySelectorAll('[data-error]').forEach((el) => el.classList.add('hidden'));
      form.querySelectorAll('.\\!border-accent').forEach((el) => el.classList.remove('!border-accent'));
      const formErr = document.getElementById('form-error');
      if (formErr) formErr.classList.add('hidden');
    }

    form.addEventListener('submit', (e) => {
      clearErrors();
      let valid = true;

      const requiredFields = form.dataset.compact
        ? ['name', 'email', 'phone', 'quantity']
        : ['name', 'company', 'email', 'phone', 'quantity'];

      requiredFields.forEach((fieldName) => {
        const input = form.querySelector(`[name="${fieldName}"]`) as HTMLInputElement | HTMLSelectElement;
        if (input && input.type !== 'hidden' && !input.value.trim()) {
          showError(fieldName);
          valid = false;
        } else if (input && input.type !== 'hidden' && !input.checkValidity()) {
          showError(fieldName);
          valid = false;
        }
      });

      // Check checkboxes only in full mode
      const checkboxes = form.querySelectorAll('input[name="needs"][type="checkbox"]:checked');
      const hasCheckboxes = form.querySelectorAll('input[name="needs"][type="checkbox"]').length > 0;
      if (hasCheckboxes && checkboxes.length === 0) {
        showError('needs');
        valid = false;
      }

      if (!valid) {
        e.preventDefault();
        return;
      }

      const submittedAt = document.getElementById('submitted_at') as HTMLInputElement;
      if (submittedAt) submittedAt.value = new Date().toISOString();

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      setTimeout(() => {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Get My Quote';
      }, 5000);
    });
  }
</script>
