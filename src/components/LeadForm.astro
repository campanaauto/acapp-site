---
/*
  LEADFORM COMPONENT
  Netlify form name: "lead"
  Required fields: name, company, email, phone, quantity, needs (checkboxes, full mode only)
  Honeypot: bot-field (hidden div)
  Used on: homepage (full + compact), /contact, /dealerships, /contractors, /franchise, /work, /process, /about
  Action: /thanks
  All Netlify attributes preserved: data-netlify="true", netlify-honeypot="bot-field", action="/thanks"
*/
interface Props {
  source: string;
  compact?: boolean;
}

const { source, compact = false } = Astro.props;
const inputClass = 'w-full h-12 bg-transparent text-white border-0 border-b border-white/20 focus:outline-none focus:border-white transition-colors duration-200 placeholder:text-white/30 text-sm font-sans px-0';
const labelClass = 'block text-xs font-medium uppercase tracking-[0.2em] text-white/50 mb-2 font-sans';
---

<form
  name="lead"
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  action="/thanks"
  id="lead-form"
  class={compact ? 'space-y-5' : 'space-y-6'}
  novalidate
>
  <div class="hidden" aria-hidden="true">
    <label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
  </div>

  <input type="hidden" name="form-name" value="lead" />
  <input type="hidden" name="source" value={source} />
  <input type="hidden" name="utm_source" id="utm_source" value="" />
  <input type="hidden" name="utm_medium" id="utm_medium" value="" />
  <input type="hidden" name="utm_campaign" id="utm_campaign" value="" />
  <input type="hidden" name="utm_content" id="utm_content" value="" />
  <input type="hidden" name="utm_term" id="utm_term" value="" />
  <input type="hidden" name="submitted_at" id="submitted_at" value="" />

  {compact ? (
    <>
      <div>
        <label for="name" class={labelClass}>Name</label>
        <input type="text" id="name" name="name" required class={inputClass} placeholder="Your full name" />
        <p class="text-accent text-xs mt-1.5 hidden" data-error="name">Required.</p>
      </div>
      <div>
        <label for="email" class={labelClass}>Email</label>
        <input type="email" id="email" name="email" required class={inputClass} placeholder="you@company.com" />
        <p class="text-accent text-xs mt-1.5 hidden" data-error="email">Valid email required.</p>
      </div>
      <div>
        <label for="phone" class={labelClass}>Phone</label>
        <input type="tel" id="phone" name="phone" required pattern="[\d\s\-\(\)\+]{7,}" class={inputClass} placeholder="(555) 123-4567" />
        <p class="text-accent text-xs mt-1.5 hidden" data-error="phone">Valid phone required.</p>
      </div>
      <div>
        <label for="quantity" class={labelClass}>Quantity</label>
        <select id="quantity" name="quantity" required class={inputClass}>
          <option value="">Select a range</option>
          <option value="Under 50">Under 50</option>
          <option value="50 to 250">50 to 250</option>
          <option value="250 to 1000">250 to 1,000</option>
          <option value="1000+">1,000+</option>
        </select>
        <p class="text-accent text-xs mt-1.5 hidden" data-error="quantity">Required.</p>
      </div>
      <input type="hidden" name="company" value="" />
      <input type="hidden" name="deadline" value="" />
      <input type="hidden" name="needs" value="" />
      <input type="hidden" name="notes" value="" />
      <button type="submit" id="submit-btn" class="w-full bg-accent text-white font-sans font-medium text-sm h-14 tracking-wide uppercase hover:bg-accent-dark transition-colors duration-300 cursor-pointer">
        Request quote
      </button>
    </>
  ) : (
    <>
      <div>
        <label for="name" class={labelClass}>Name</label>
        <input type="text" id="name" name="name" required class={inputClass} placeholder="Your full name" />
        <p class="text-accent text-xs mt-1.5 hidden" data-error="name">Required.</p>
      </div>
      <div>
        <label for="company" class={labelClass}>Company</label>
        <input type="text" id="company" name="company" required class={inputClass} placeholder="Company name" />
        <p class="text-accent text-xs mt-1.5 hidden" data-error="company">Required.</p>
      </div>
      <div>
        <label for="email" class={labelClass}>Email</label>
        <input type="email" id="email" name="email" required class={inputClass} placeholder="you@company.com" />
        <p class="text-accent text-xs mt-1.5 hidden" data-error="email">Valid email required.</p>
      </div>
      <div>
        <label for="phone" class={labelClass}>Phone</label>
        <input type="tel" id="phone" name="phone" required pattern="[\d\s\-\(\)\+]{7,}" class={inputClass} placeholder="(555) 123-4567" />
        <p class="text-accent text-xs mt-1.5 hidden" data-error="phone">Valid phone required.</p>
      </div>
      <div>
        <label for="deadline" class={labelClass}>Deadline</label>
        <input type="date" id="deadline" name="deadline" class={inputClass} />
      </div>
      <div>
        <label for="quantity" class={labelClass}>Quantity</label>
        <select id="quantity" name="quantity" required class={inputClass}>
          <option value="">Select a range</option>
          <option value="Under 50">Under 50</option>
          <option value="50 to 250">50 to 250</option>
          <option value="250 to 1000">250 to 1,000</option>
          <option value="1000+">1,000+</option>
        </select>
        <p class="text-accent text-xs mt-1.5 hidden" data-error="quantity">Required.</p>
      </div>
      <fieldset>
        <legend class={labelClass}>What do you need?</legend>
        <div class="grid grid-cols-2 gap-3 mt-2">
          {['Apparel', 'Promo', 'Print', 'Not sure yet'].map((need) => (
            <label class="flex items-center gap-3 text-white/60 text-sm cursor-pointer font-sans">
              <input type="checkbox" name="needs" value={need} class="w-4 h-4 accent-accent" />
              {need}
            </label>
          ))}
        </div>
        <p class="text-accent text-xs mt-1.5 hidden" data-error="needs">Select at least one.</p>
      </fieldset>
      <div>
        <label for="notes" class={labelClass}>Notes</label>
        <textarea id="notes" name="notes" rows="3" class="w-full bg-transparent text-white border-0 border-b border-white/20 focus:outline-none focus:border-white transition-colors duration-200 placeholder:text-white/30 text-sm font-sans px-0 py-3" placeholder="Colors, quantities, anything helpful."></textarea>
      </div>
      <button type="submit" id="submit-btn" class="w-full bg-accent text-white font-sans font-medium text-sm h-14 tracking-wide uppercase hover:bg-accent-dark transition-colors duration-300 cursor-pointer">
        Request quote
      </button>
    </>
  )}

  <p id="form-error" class="text-accent text-center text-sm hidden font-sans">
    Submission failed. Text us at <a href="sms:+17724802284" class="underline">(772) 480-2284</a> or email <a href="mailto:info@acapp.us" class="underline">info@acapp.us</a>.
  </p>
</form>

<script>
  const params = new URLSearchParams(window.location.search);
  ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'].forEach((key) => {
    const el = document.getElementById(key) as HTMLInputElement;
    if (el && params.get(key)) el.value = params.get(key) || '';
  });

  const form = document.getElementById('lead-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  if (form && submitBtn) {
    function showError(name: string) {
      const el = form.querySelector(`[data-error="${name}"]`) as HTMLElement;
      if (el) el.classList.remove('hidden');
    }
    function clearErrors() {
      form.querySelectorAll('[data-error]').forEach((el) => el.classList.add('hidden'));
      document.getElementById('form-error')?.classList.add('hidden');
    }
    form.addEventListener('submit', (e) => {
      clearErrors();
      let valid = true;
      const fields = form.querySelectorAll('input[name="needs"][type="checkbox"]').length > 0
        ? ['name', 'company', 'email', 'phone', 'quantity']
        : ['name', 'email', 'phone', 'quantity'];
      fields.forEach((f) => {
        const input = form.querySelector(`[name="${f}"]`) as HTMLInputElement | HTMLSelectElement;
        if (input && input.type !== 'hidden' && (!input.value.trim() || !input.checkValidity())) {
          showError(f); valid = false;
        }
      });
      const cbs = form.querySelectorAll('input[name="needs"][type="checkbox"]:checked');
      if (form.querySelectorAll('input[name="needs"][type="checkbox"]').length > 0 && cbs.length === 0) {
        showError('needs'); valid = false;
      }
      if (!valid) { e.preventDefault(); return; }
      const ts = document.getElementById('submitted_at') as HTMLInputElement;
      if (ts) ts.value = new Date().toISOString();
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      setTimeout(() => { submitBtn.disabled = false; submitBtn.textContent = 'Request quote'; }, 5000);
    });
  }
</script>
