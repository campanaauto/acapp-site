---
interface Props {
  source: string;
}
const { source } = Astro.props;
---

<!-- Desktop-only sticky sidebar form, appears after scrolling past hero -->
<div id="sticky-sidebar" class="sticky-sidebar hidden lg:block fixed top-[calc(36px+64px+2rem)] right-6 w-[320px] z-40">
  <div class="bg-white rounded-sm shadow-xl border border-charcoal/10 p-6">
    <h3 class="text-base font-bold text-charcoal mb-4">Get a quick quote</h3>

    <form
      name="lead"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      action="/thanks"
      id="sidebar-form"
      class="space-y-3"
      novalidate
    >
      <div class="hidden" aria-hidden="true">
        <label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
      </div>
      <input type="hidden" name="form-name" value="lead" />
      <input type="hidden" name="source" value={`${source}-sidebar`} />
      <input type="hidden" name="utm_source" value="" />
      <input type="hidden" name="utm_medium" value="" />
      <input type="hidden" name="utm_campaign" value="" />
      <input type="hidden" name="utm_content" value="" />
      <input type="hidden" name="utm_term" value="" />
      <input type="hidden" name="submitted_at" id="sidebar-submitted-at" value="" />

      <div>
        <label class="block text-xs font-semibold text-charcoal/60 mb-1">Email *</label>
        <input type="email" name="email" required class="w-full h-10 px-3 text-sm rounded-sm bg-offwhite text-charcoal border border-charcoal/10 focus:outline-none focus:ring-2 focus:ring-accent transition-all" placeholder="you@company.com" />
      </div>

      <div>
        <label class="block text-xs font-semibold text-charcoal/60 mb-1">Cell phone for text updates</label>
        <input type="tel" name="phone" pattern="[\d\s\-\(\)\+]{7,}" class="w-full h-10 px-3 text-sm rounded-sm bg-offwhite text-charcoal border border-charcoal/10 focus:outline-none focus:ring-2 focus:ring-accent transition-all" placeholder="(555) 123-4567" />
      </div>

      <div>
        <label class="block text-xs font-semibold text-charcoal/60 mb-1">What do you need?</label>
        <select name="needs" class="w-full h-10 px-3 text-sm rounded-sm bg-offwhite text-charcoal border border-charcoal/10 focus:outline-none focus:ring-2 focus:ring-accent transition-all">
          <option value="">Select one</option>
          <option value="Apparel">Apparel</option>
          <option value="Promo">Promo</option>
          <option value="Print">Print</option>
          <option value="Not sure yet">Not sure yet</option>
        </select>
      </div>

      <div>
        <label class="block text-xs font-semibold text-charcoal/60 mb-1">Company</label>
        <input type="text" name="company" class="w-full h-10 px-3 text-sm rounded-sm bg-offwhite text-charcoal border border-charcoal/10 focus:outline-none focus:ring-2 focus:ring-accent transition-all" placeholder="Company name" />
      </div>

      <div>
        <label class="block text-xs font-semibold text-charcoal/60 mb-1">Notes</label>
        <textarea name="notes" rows="2" class="w-full px-3 py-2 text-sm rounded-sm bg-offwhite text-charcoal border border-charcoal/10 focus:outline-none focus:ring-2 focus:ring-accent transition-all" placeholder="Brief description..."></textarea>
      </div>

      <!-- Hidden fields for main lead form compatibility -->
      <input type="hidden" name="name" value="" />
      <input type="hidden" name="deadline" value="" />
      <input type="hidden" name="quantity" value="" />

      <button type="submit" class="w-full bg-accent hover:bg-accent-dark text-white font-semibold text-sm py-2.5 rounded-sm transition-all duration-300 cursor-pointer">
        Get My Quote
      </button>

      <p class="text-charcoal/40 text-xs text-center">Or <a href="#quote" class="underline hover:text-accent">scroll down for full form</a></p>
    </form>
  </div>
</div>

<script>
  const sidebar = document.getElementById('sticky-sidebar');
  if (sidebar) {
    const hero = document.querySelector('section:first-of-type');
    if (hero) {
      const obs = new IntersectionObserver(([entry]) => {
        if (entry.isIntersecting) {
          sidebar.classList.remove('visible');
        } else {
          sidebar.classList.add('visible');
        }
      }, { threshold: 0.1 });
      obs.observe(hero);
    }

    const sidebarForm = document.getElementById('sidebar-form') as HTMLFormElement;
    sidebarForm?.addEventListener('submit', () => {
      const ts = document.getElementById('sidebar-submitted-at') as HTMLInputElement;
      if (ts) ts.value = new Date().toISOString();
    });
  }
</script>
